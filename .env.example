# ─── Backend (copy to backend/.env) ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# MongoDB — matches docker-compose.yml
MONGODB_URI=mongodb://inventory:inventory_local@localhost:27017/inventory?authSource=admin

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# CORS — frontend dev server
CORS_ORIGIN=http://localhost:3000

# ─── Frontend (copy to frontend/.env.local) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
JWT_SECRET=change-me-to-a-long-random-string-in-production
